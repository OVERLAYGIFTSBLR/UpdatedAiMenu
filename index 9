    .header-jp    { font-family: 'Noto Serif JP', serif; font-size: 13px; letter-spacing: 5px; color: rgba(255,255,255,0.45); margin-bottom: 10px; }
    .header-title { font-family: 'Playfair Display', serif; font-size: clamp(32px,6vw,52px); font-weight: 400; letter-spacing: -0.5px; line-height: 1.05; margin-bottom: 8px; }
