    .header-sub   { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 18px; }

    .ar-badge {
      display: inline-flex; align-items: center; gap: 7px;
      border: 1px solid rgba(255,255,255,0.18); border-radius: 20px;
      padding: 6px 14px; font-size: 11px; letter-spacing: 1px; color: rgba(255,255,255,0.7);
    }
    .ar-dot { width:7px; height:7px; border-radius:50%; background:#e74c3c; flex-shrink:0; animation: pulse 1.6s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.35;transform:scale(0.8)} }

    /* ── LANGUAGE PICKER ─────────────────────────────── */
    #language-picker { position:relative; z-index:10; margin-bottom:16px; }
    #lang-select {
      background: rgba(255,255,255,0.1); color: white;
      border: 1px solid rgba(255,255,255,0.3); border-radius: 6px;
      padding: 6px 10px; font-family: 'DM Sans', sans-serif;
      font-size: 12px; cursor: pointer; outline: none;
    }
    #lang-select option { background: #1a1208; color: white; }

    /* ── STICKY TABS ─────────────────────────────────── */
    .tabs-wrap {
      position: sticky; top: 0; z-index: 100;
      background: var(--paper); border-bottom: 1px solid var(--border); padding: 0 1rem;
    }
    .tabs-inner {
      max-width: 720px; margin: 0 auto; display: flex; gap: 4px;
      overflow-x: auto; scrollbar-width: none; padding: 10px 0;
    }
    .tabs-inner::-webkit-scrollbar { display: none; }
    .tab-btn {
      flex-shrink: 0; padding: 7px 18px; border-radius: 20px;
      border: 1px solid var(--border); background: transparent;
      color: var(--muted); font-family: 'DM Sans', sans-serif;
      font-size: 13px; cursor: pointer; transition: all 0.18s ease; white-space: nowrap;
    }
    .tab-btn:hover { border-color: var(--border-md); color: var(--ink); }
    .tab-btn.active { background: var(--ink); color: #fff; border-color: var(--ink); }

    /* ── MAIN ────────────────────────────────────────── */
    .main { max-width: 720px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }

    .state-box { text-align: center; padding: 4rem 1rem; color: var(--muted); }
    .state-box .spinner {
