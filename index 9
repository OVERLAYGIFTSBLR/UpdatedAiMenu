    .card-body { flex: 1; min-width: 0; }
    .name-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; margin-bottom: 3px; }
    .dish-name { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 400; color: var(--ink); }
    .dish-jp   { font-family: 'Noto Serif JP', serif; font-size: 12px; color: var(--muted); }
    .tags-row  { display: flex; gap: 4px; flex-wrap: wrap; margin: 5px 0 7px; }
    .tag       { font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 500; letter-spacing: 0.3px; }
    .tag-veg   { background: #d6f0e4; color: var(--tag-veg); }
