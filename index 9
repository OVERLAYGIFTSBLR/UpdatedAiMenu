    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:       #1a1208;
      --paper:     #fdf8f0;
      --surface:   #fff9f2;
      --accent:    #c0392b;
      --gold:      #b8860b;
      --muted:     #7a6a55;
      --border:    rgba(139,100,50,0.15);
      --border-md: rgba(139,100,50,0.28);
      --tag-veg:   #2d6a4f;
      --tag-new:   #c0392b;
      --tag-dotd:  #b8860b;
      --shadow:    0 4px 20px rgba(26,18,8,0.07);
