    .modal-close:hover { background: rgba(255,255,255,0.25); }

    .modal-body { padding: 1.4rem 1.5rem 1.8rem; }
    .modal-name { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 400; margin-bottom: 4px; }
    .modal-jp   { font-family: 'Noto Serif JP', serif; font-size: 14px; color: var(--muted); margin-bottom: 12px; }
    .modal-desc {
      font-size: 14px; color: var(--muted); line-height: 1.7;
