const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
              (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

// ─────────────────────────────────────────────────────────────
//  CSV PARSER
// ─────────────────────────────────────────────────────────────
function parseCSV(text) {
  const lines = text.trim().split('\n');
  if (lines.length < 2) return [];
  const headers = splitLine(lines[0]).map(h => h.trim().toLowerCase());
  return lines.slice(1).map(line => {
    const vals = splitLine(line);
    const obj  = {};
    headers.forEach((h, i) => { obj[h] = (vals[i] || '').trim(); });
    return obj;
  });
}

function splitLine(line) {
  const result = []; let cur = ''; let inQ = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"' && !inQ) { inQ = true; continue; }
    if (ch === '"' && inQ)  { if (line[i+1] === '"') { cur += '"'; i++; } else { inQ = false; } continue; }
    if (ch === ',' && !inQ) { result.push(cur); cur = ''; continue; }
    cur += ch;
  }
  result.push(cur);
  return result;
}

// ─────────────────────────────────────────────────────────────
//  ROW → DISH
// ─────────────────────────────────────────────────────────────
function rowToDish(row) {
  const truthy = v => ['true','yes','1'].includes((v || '').toLowerCase());

  const sfx  = currentLang !== 'en' ? `_${currentLang}` : '';
  const desc = row[`description${sfx}`] || row['description'] || '';
  const name = row[`name${sfx}`]        || row['name']        || '';

  const rawGlb  = (row['glb_url'] || '').trim();
  const glbPath = rawGlb ? decodeURIComponent(rawGlb) : '';

  // ✅ SCALE: read directly from sheet — this is the ONLY scale used
  //    No fallback to 1 — if sheet says 0.5, the model is 0.5x
  const scale = parseFloat(row['scale'] || '1') || 1;

  return {
    id:        row['id']       || '',
    name,
    category:  (row['category'] || 'other').toLowerCase(),
    jp:        row['jp_name']  || '',
    desc,
    price:     parseInt(row['price'] || '0', 10),
    veg:       truthy(row['veg']),
    dotd:      truthy(row['dish of the day'] || row['dotd']),
    isNew:     truthy(row['new']),
    available: truthy(row['available']),
    glbPath,
    scale,    // ← exact value from sheet
    emoji:    EMOJI_MAP[(row['name'] || '').toLowerCase()] || '🍽️',
  };
}

// ─────────────────────────────────────────────────────────────
//  HELPERS
// ─────────────────────────────────────────────────────────────
function tagHTML(d) {
  const t = I18N[currentLang] || I18N.en;
  return [
    d.veg   ? `<span class="tag tag-veg">🌿 ${t.veg}</span>` : '',
    d.isNew ? '<span class="tag tag-new">new</span>'          : '',
    d.dotd  ? `<span class="tag tag-dotd">★ chef's pick</span>` : '',
  ].join('');
}

function catLabel(cat) {
  const map = CAT_LABELS[cat];
  return map ? (map[currentLang] || map.en) : (cat.charAt(0).toUpperCase() + cat.slice(1));
}

// ─────────────────────────────────────────────────────────────
//  RENDER TABS
// ─────────────────────────────────────────────────────────────
function renderTabs() {
  const cats = ['all', ...new Set(allDishes.map(d => d.category))];
  const wrap = document.getElementById('tabs-inner');
  wrap.innerHTML = cats.map(c =>
    `<button class="tab-btn${c === activeCategory ? ' active' : ''}" data-cat="${c}">${catLabel(c)}</button>`
  ).join('');
  wrap.querySelectorAll('.tab-btn').forEach(btn =>
    btn.addEventListener('click', () => { activeCategory = btn.dataset.cat; renderTabs(); renderItems(); })
  );
}

// ─────────────────────────────────────────────────────────────
//  RENDER ITEMS
// ─────────────────────────────────────────────────────────────
const SVG_CUBE = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`;

function cardHTML(d) {
  return `
    <div class="menu-card${d.available ? '' : ' unavailable'}" data-id="${d.id}" role="button" tabindex="0" aria-label="View ${d.name} in 3D">
      <div class="card-row">
        <div class="card-thumb">
          ${d.glbPath
            ? `<model-viewer
                src="${d.glbPath}"
                camera-orbit="0deg 70deg 0.9m"
                disable-zoom
                disable-pan
                interaction-prompt="none"
                loading="lazy"
                reveal="auto"
                style="width:100%;height:100%;background:transparent;--progress-bar-height:0px;pointer-events:none;"
              ></model-viewer>`
            : `<span class="thumb-emoji">${d.emoji}</span>`
          }
          ${d.glbPath ? '<span class="ar-pill">AR</span>' : ''}
        </div>
        <div class="card-body">
          <div class="name-row">
            <span class="dish-name">${d.name}</span>
            ${d.jp ? `<span class="dish-jp">${d.jp}</span>` : ''}
          </div>
          <div class="tags-row">${tagHTML(d)}</div>
          <p class="dish-desc">${d.desc}</p>
          <div class="card-footer">
            <div class="dish-price"><span class="price-sym">₹</span>${d.price.toLocaleString('en-IN')}</div>
            ${d.glbPath ? `<button class="ar-btn" data-id="${d.id}">${SVG_CUBE} View in AR</button>` : ''}
          </div>
        </div>
      </div>
    </div>`;
}

function renderItems() {
  const filtered  = activeCategory === 'all' ? allDishes : allDishes.filter(d => d.category === activeCategory);
  const container = document.getElementById('items-container');

  if (activeCategory === 'all') {
    const grouped = {};
    filtered.forEach(d => { (grouped[d.category] = grouped[d.category] || []).push(d); });
    container.innerHTML = Object.entries(grouped).map(([cat, items]) =>
      `<div class="section-label"><span></span>${catLabel(cat)}<span></span></div>
       <div class="items-grid">${items.map(cardHTML).join('')}</div>`
    ).join('');
  } else {
    container.innerHTML = `<div class="items-grid">${filtered.map(cardHTML).join('')}</div>`;
  }

  container.querySelectorAll('.menu-card').forEach(card =>
    card.addEventListener('click', () => openModal(card.dataset.id))
  );
  container.querySelectorAll('.ar-btn').forEach(btn =>
    btn.addEventListener('click', e => { e.stopPropagation(); openModal(btn.dataset.id); })
  );
}

// ─────────────────────────────────────────────────────────────
//  MODAL — FIXED SCALE, NO PINCH ZOOM
//
//  HOW FIXED SCALE WORKS:
//  1. `scale="${s} ${s} ${s}"` sets the model's world scale from sheet.
//  2. `camera-orbit` locks the camera to a fixed distance/angle.
//  3. `min-camera-orbit` = `max-camera-orbit` = same value → 
//     orbit controls are constrained so the user CANNOT zoom in/out.
//  4. `disable-zoom` attribute disables scroll-wheel zoom.
//  5. `touch-action: none` on the element prevents browser
//     from interpreting pinch as page zoom (CSS already set above).
//  6. `interaction-prompt="none"` removes the hand animation
//     that encourages zooming.
//
//  AR uses the same scale — ar-scale="fixed" prevents AR from
//  auto-scaling the model when placed in the real world.
// ─────────────────────────────────────────────────────────────
function openModal(id) {
  const d = allDishes.find(x => x.id === id);
  if (!d) return;

  document.getElementById('modal-name').textContent = d.name;
  document.getElementById('modal-jp').textContent   = d.jp;
  document.getElementById('modal-desc').textContent = d.desc;
  document.getElementById('modal-price').innerHTML  =
    `<span style="font-family:'DM Sans',sans-serif;font-size:14px;color:var(--muted)">₹</span>${d.price.toLocaleString('en-IN')}`;
  document.getElementById('modal-tags').innerHTML   = tagHTML(d);
  document.getElementById('modal-tags2').innerHTML  = tagHTML(d);

  // Reset badges
  const arBadge   = document.getElementById('mv-ar-badge');
  const scaleInfo = document.getElementById('scale-info');
  arBadge.classList.remove('visible');
  scaleInfo.textContent = 'Actual portion size';

  const vw   = document.getElementById('modal-viewer-wrap');
  const prev = vw.querySelector('model-viewer, .no-model');
  if (prev) prev.remove();

  if (d.glbPath) {
    // ── Build model-viewer programmatically ──────────────────
    const mv = document.createElement('model-viewer');

    // ✅ Source
    mv.setAttribute('src', d.glbPath);

    // ✅ iOS Quick Look — provide USDZ if you have it
    if (isIOS) {
      mv.setAttribute('ios-src', d.glbPath.replace(/\.glb$/i, '.usdz'));
    }

    // ✅ EXACT SCALE FROM SHEET — applied to model world transform
    const s = d.scale.toFixed(6);
    mv.setAttribute('scale', `${s} ${s} ${s}`);

    // ✅ LOCK CAMERA so user cannot zoom and change perceived size
    //    Orbit: azimuth | elevation | radius
    //    Both min and max set to the same value = locked
    mv.setAttribute('camera-orbit',     '0deg 70deg 0.7m');
    mv.setAttribute('min-camera-orbit', 'auto 70deg 0.7m');
    mv.setAttribute('max-camera-orbit', 'auto 70deg 0.7m');

    // ✅ DISABLE ZOOM — belt & suspenders alongside locked orbit
    mv.setAttribute('disable-zoom', '');

    // ✅ AR — uses same scale, no auto-resize in real world
    mv.setAttribute('ar',            '');
    mv.setAttribute('ar-modes',      'webxr scene-viewer quick-look');
    mv.setAttribute('ar-placement',  'floor');
    mv.setAttribute('ar-scale',      'fixed');   // ← AR won't auto-scale either

    // ── Viewer experience ────────────────────────────────────
    mv.setAttribute('camera-controls',    '');    // still allow rotation (not zoom)
    mv.setAttribute('auto-rotate',        '');
    mv.setAttribute('auto-rotate-delay',  '1000');
    mv.setAttribute('rotation-per-second','30deg');
    mv.setAttribute('shadow-intensity',   '1');
    mv.setAttribute('environment-image',  'neutral');
    mv.setAttribute('exposure',           '1.1');
    mv.setAttribute('interaction-prompt', 'none'); // no "pinch" hint shown
    mv.setAttribute('loading',            'eager');
    mv.setAttribute('reveal',             'auto');

    mv.style.cssText = 'display:block;width:100%;height:300px;background:transparent;touch-action:none;';

    // ── Loading overlay (fast feedback while GLB downloads) ──
    const loadOverlay = document.createElement('div');
    loadOverlay.className = 'mv-loading-overlay';
    loadOverlay.id = 'mv-load-overlay';
    loadOverlay.innerHTML = `
      <div class="mv-loader-ring"></div>
      <div class="mv-loader-bar-track"><div class="mv-loader-bar-fill" id="mv-bar"></div></div>
      <div class="mv-loader-label">Loading model</div>
    `;
    vw.insertBefore(loadOverlay, arBadge);
    vw.insertBefore(mv, loadOverlay);

    // ── Wire events ──────────────────────────────────────────
    // ✅ FAST LOAD: progress bar fills as bytes arrive
    mv.addEventListener('progress', (e) => {
      const bar = document.getElementById('mv-bar');
      if (bar) bar.style.width = Math.round(e.detail.totalProgress * 100) + '%';
    });

    // ✅ FAST AR: enable AR button the instant model is parsed
    mv.addEventListener('load', () => {
      loadOverlay.classList.add('hidden');
      arBadge.classList.add('visible');
      // Update scale chip with human-readable info
      scaleInfo.textContent = `Scale: ${d.scale}× · Actual portion size`;
      setTimeout(() => loadOverlay.remove(), 500);
    });

    mv.addEventListener('error', () => {
      const label = loadOverlay.querySelector('.mv-loader-label');
      const ring  = loadOverlay.querySelector('.mv-loader-ring');
      if (label) label.textContent = 'Model unavailable';
      if (ring)  ring.style.display = 'none';
    });

  } else {
    // Fallback: no GLB
    const ph = document.createElement('div');
    ph.className = 'no-model';
    ph.style.cssText = 'display:flex;flex-direction:column;align-items:center;justify-content:center;height:300px;gap:10px;';
    ph.innerHTML = `<span style="font-size:72px">${d.emoji}</span>
                    <span style="font-size:11px;letter-spacing:1px;color:rgba(255,255,255,0.3)">3D model not available</span>`;
    vw.insertBefore(ph, arBadge);
  }

  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

// ─────────────────────────────────────────────────────────────
//  CLOSE MODAL — remove model-viewer to free memory
// ─────────────────────────────────────────────────────────────
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
  const mv = document.querySelector('#modal-viewer-wrap model-viewer');
  if (mv) mv.remove();
  const loadOverlay = document.getElementById('mv-load-overlay');
  if (loadOverlay) loadOverlay.remove();
  document.getElementById('mv-ar-badge').classList.remove('visible');
}

document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('modal-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('modal-overlay')) closeModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

// ─────────────────────────────────────────────────────────────
//  LANGUAGE SWITCH
// ─────────────────────────────────────────────────────────────
document.getElementById('lang-select').addEventListener('change', e => {
  currentLang = e.target.value;
  const t = I18N[currentLang] || I18N.en;
  document.getElementById('ui-sub-tag').textContent  = t.sub;
  document.getElementById('ui-ar-badge').textContent = t.badge;
  document.getElementById('ui-loading').textContent  = t.loading;
  allDishes = rawRows.map(rowToDish).filter(d => d.name);
  renderTabs();
  renderItems();
});

// ─────────────────────────────────────────────────────────────
//  INIT
// ─────────────────────────────────────────────────────────────
async function init() {
  const loadingEl = document.getElementById('loading-state');
  const container = document.getElementById('items-container');
  try {
    const res  = await fetch(CSV_URL);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const text = await res.text();
    rawRows    = parseCSV(text);
    allDishes  = rawRows.map(rowToDish).filter(d => d.name);
    if (!allDishes.length) throw new Error('No dishes found.');
    loadingEl.style.display = 'none';
    container.style.display = 'block';
    renderTabs();
    renderItems();
  } catch (err) {
    console.error('Menu load error:', err);
    loadingEl.innerHTML = `
      <p style="color:#c0392b;font-weight:500;margin-bottom:8px">Could not load menu data</p>
      <p style="font-size:13px;line-height:1.7">
        Make sure your sheet is published:<br>
        <strong>File → Share → Publish to web → CSV</strong><br><br>
        Sheet ID in use:<br>
        <code style="background:#f0e8d8;padding:2px 6px;border-radius:4px;font-size:11px">${SHEET_ID}</code>
      </p>`;
  }
}

init();
</script>
