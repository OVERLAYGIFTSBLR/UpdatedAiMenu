      position: relative;
      overflow: hidden;
    }

    .site-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 50%, rgba(192,57,43,0.12) 0%, transparent 60%),
        radial-gradient(circle at 80% 50%, rgba(184,134,11,0.10) 0%, transparent 60%);
      pointer-events: none;
