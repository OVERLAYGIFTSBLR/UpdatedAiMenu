    /* ── MODAL ───────────────────────────────────────── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(8,6,2,0.72); z-index: 9000;
      align-items: flex-end; justify-content: center; padding: 0;
      backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    }
    @media (min-width: 540px) { .modal-overlay { align-items: center; padding: 1.5rem; } }
    .modal-overlay.open { display: flex; }

    .modal-card {
      background: var(--paper); border-radius: 20px 20px 0 0;
      width: 100%; max-width: 500px; max-height: 92svh;
      overflow-y: auto; overscroll-behavior: contain;
      position: relative; animation: slideUp 0.25s ease;
    }
    @media (min-width: 540px) { .modal-card { border-radius: 20px; animation: fadeIn 0.2s ease; } }
    @keyframes slideUp { from { transform: translateY(40px); opacity: 0; } to { transform: none; opacity: 1; } }
    @keyframes fadeIn  { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: none; } }

    /* ── MODEL VIEWER WRAPPER ────────────────────────── */
    .modal-viewer-wrap {
      width: 100%; height: 300px;
      background: linear-gradient(160deg, #1c140a 0%, #2e2112 100%);
      border-radius: 20px 20px 0 0; position: relative; overflow: hidden;
    }

    /* ✅ FIXED SCALE: model-viewer itself MUST NOT be resized by user.
       touch-action: none  → disables pinch-zoom on the element entirely.
       pointer-events on the slot disables wheel zoom on desktop too.      */
    model-viewer {
      display: block;
      width: 100%;
      height: 300px;
      background: transparent;
      --progress-bar-color: #b8860b;
      --progress-mask: transparent;
      /* Disable pinch zoom / scroll zoom on the 3D viewer */
      touch-action: none;
    }

    /* ── CUSTOM LOADING STATE inside modal viewer ─────── */
    .mv-loading-overlay {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 10px;
      background: linear-gradient(160deg, #1c140a 0%, #2e2112 100%);
      z-index: 5; transition: opacity 0.4s ease; pointer-events: none;
    }
    .mv-loading-overlay.hidden { opacity: 0; }

    .mv-loader-ring {
      width: 40px; height: 40px;
      border: 2px solid rgba(184,134,11,0.15);
      border-top-color: #b8860b;
      border-radius: 50%;
      animation: spin 0.9s linear infinite;
    }

    .mv-loader-bar-track {
      width: 80px; height: 2px;
      background: rgba(184,134,11,0.12); border-radius: 2px; overflow: hidden;
    }
    .mv-loader-bar-fill {
      height: 100%; background: #b8860b; width: 0%;
      border-radius: 2px; transition: width 0.2s ease;
    }
    .mv-loader-label {
      font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(184,134,11,0.6);
    }

    /* ── AR READY BADGE inside viewer ──────────────────── */
    .mv-ar-badge {
      position: absolute; top: 10px; left: 50%; transform: translateX(-50%) translateY(-6px);
      background: rgba(26,18,8,0.8); border: 1px solid #b8860b;
      border-radius: 20px; padding: 4px 12px;
      font-size: 9px; letter-spacing: 0.15em; color: #d4ae52;
      text-transform: uppercase; opacity: 0;
